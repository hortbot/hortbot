								<td>
									@convertedCommand(a.Response)
								</td>
								<td>{ fmt.Sprint(a.Count) }</td>
								<td>{ a.Editor }</td>
								<td>{ a.UpdatedAt.Format(time.RFC3339) }</td>
							</tr>
						}
					</tbody>
				</table>
			}
