templ ChannelAutorepliesPage(channel *models.Channel, autoreplies models.AutoreplySlice) {
	@PageTemplate(getBrand(ctx)+" - "+displayNameFor(channel), channelMeta(), channelScripts(), channelAutorepliesBody(channel, autoreplies))
}

// Lists page
func listsItems(lists models.CommandListSlice) [][]string {
	result := make([][]string, len(lists))
	for i, l := range lists {
		result[i] = l.Items
	}
	return result
}

templ channelListsBody(channel *models.Channel, lists models.CommandListSlice) {
	@channelSidebarMobile(channel, "lists")
	<div class="columns is-fullheight is-clipped">
		@channelSidebar(channel, "lists")
		<div class="column is-main-content content">
			<span class="title is-1">{ displayNameFor(channel) }</span><span class="subtitle is-3">Lists</span>
			<hr/>
			if len(lists) == 0 {
				<p>No lists.</p>
			} else {
				<table
					class="table is-striped is-hoverable is-fullwidth"
					data-toggle="table"
					data-sort-class="table-active"
					data-sort-name="command"
					data-search="true"
					data-sortable="true"
					data-detail-view="true"
					data-detail-formatter="detailFormatter"
				>
					<thead>
						<tr>
							<th data-sortable="true" data-field="command">Command</th>
							<th data-sortable="true">Access</th>
							<th data-sortable="true">Count</th>
							<th data-sortable="true">Editor</th>
							<th data-sortable="true" data-formatter="timeFormatter" data-sorter="timeSorter">Edited</th>
						</tr>
					</thead>
					<tbody>
						for _, l := range lists {
							<tr data-has-detail-view="true">
								<td><code>{ channel.Prefix }{ l.R.CommandInfo.Name }</code></td>
								<td>
									@accessLevel(l.R.CommandInfo.AccessLevel)
								</td>
								<td>{ fmt.Sprint(l.R.CommandInfo.Count) }</td>
								<td>{ l.R.CommandInfo.Editor }</td>
								<td>{ l.UpdatedAt.Format(time.RFC3339) }</td>
							</tr>
						}
					</tbody>
				</table>
			}
		</div>
	</div>
}

templ channelListsScripts(lists models.CommandListSlice) {
	@channelScripts()
	<script>
	var all = {{ listsItems(lists) }};

	function detailFormatter(index, row) {
		var html = ["<p><ol>"];

		var items = all[index];

		if (items.length == 0) {
			return "<p>No items.</p>"
		}

		for (var i = 0; i < items.length; i++) {
			html.push("<li>");
			var div = document.createElement("div");
			div.innerText = items[i];
			html.push(div.innerHTML);
			html.push("</li>");
		}

		html.push("</ol></p>")

		return html.join("");
	}
	</script>
}

templ ChannelListsPage(channel *models.Channel, lists models.CommandListSlice) {
	@PageTemplate(getBrand(ctx)+" - "+displayNameFor(channel), channelMeta(), channelListsScripts(lists), channelListsBody(channel, lists))
}

// Regulars page
templ channelRegularsBody(channel *models.Channel) {
	@channelSidebarMobile(channel, "regulars")
	<div class="columns is-fullheight is-clipped">
		@channelSidebar(channel, "regulars")
		<div class="column is-main-content content">
			<span class="title is-1">{ displayNameFor(channel) }</span><span class="subtitle is-3">Regulars</span>
			<hr/>
			if len(channel.CustomRegulars) == 0 {
				<p>No regulars.</p>
			} else {
				<p>The following users are considered regulars in chat:</p>
				<ul>
					for _, reg := range channel.CustomRegulars {
						<li>{ reg }</li>
					}
				</ul>
			}
		</div>
	</div>
}

templ ChannelRegularsPage(channel *models.Channel) {
	@PageTemplate(getBrand(ctx)+" - "+displayNameFor(channel), channelMeta(), channelScripts(), channelRegularsBody(channel))
}

// Chat rules page
templ channelRulesBody(channel *models.Channel) {
	@channelSidebarMobile(channel, "chatrules")
	<div class="columns is-fullheight is-clipped">
		@channelSidebar(channel, "chatrules")
		<div class="column is-main-content content">
			<span class="title is-1">{ displayNameFor(channel) }</span><span class="subtitle is-3">Chat rules</span>
			<hr/>
			<h2>Allowed URLs</h2>
			if len(channel.PermittedLinks) == 0 {
				<p>No allowed URLs.</p>
			} else {
				<p>The following URL patterns are allowed:</p>
				<ul>
					for _, link := range channel.PermittedLinks {
						<li><code>{ link }</code></li>
					}
				</ul>
			}
			<h2>Banned phrases</h2>
			if len(channel.FilterBannedPhrasesPatterns) == 0 {
				<p>No banned phrases.</p>
			} else {
				<p>The following phrases are banned:</p>
				<ul>
					for _, p := range channel.FilterBannedPhrasesPatterns {
						<li><code>{ p }</code></li>
					}
				</ul>
			}
		</div>
	</div>
}

templ ChannelRulesPage(channel *models.Channel) {
	@PageTemplate(getBrand(ctx)+" - "+displayNameFor(channel), channelMeta(), channelScripts(), channelRulesBody(channel))
}

// Scheduled page
func formatDuration(delay int, unit time.Duration) string {
	return durafmt.Parse(time.Duration(delay) * unit).String()
}

templ channelScheduledBody(channel *models.Channel, repeated models.RepeatedCommandSlice, scheduled models.ScheduledCommandSlice) {
	@channelSidebarMobile(channel, "scheduled")
	<div class="columns is-fullheight is-clipped">
		@channelSidebar(channel, "scheduled")
		<div class="column is-main-content content">
			<span class="title is-1">{ displayNameFor(channel) }</span><span class="subtitle is-3">Repeated / scheduled commands</span>
			<hr/>
			<h2>Repeated commands</h2>
			if len(repeated) == 0 {
				<p>No repeated commands.</p>
			} else {
				<table
					class="table is-striped is-hoverable is-fullwidth"
					data-toggle="table"
					data-sort-class="table-active"
					data-sort-name="enabled"
					data-sort-order="desc"
					data-search="true"
					data-sortable="true"
				>
					<thead>
						<tr>
							<th data-sortable="true">Command</th>
							<th data-sortable="true" data-field="enabled">Enabled</th>
							<th data-sortable="true">Interval</th>
							<th data-sortable="true">Message diff</th>
						</tr>
					</thead>
					<tbody>
						for _, c := range repeated {
							<tr>
								<td><code>{ channel.Prefix }{ c.R.CommandInfo.Name }</code></td>
								<td>
									@yesNo(c.Enabled)
								</td>
								<td>Every { formatDuration(c.Delay, time.Second) }</td>
								<td>{ fmt.Sprint(c.MessageDiff) }</td>
							</tr>
						}
					</tbody>
				</table>
			}
			<h2>Scheduled commands</h2>
			if len(scheduled) == 0 {
				<p>No scheduled commands.</p>
			} else {
				<table
					class="table is-striped is-hoverable is-fullwidth"
					data-toggle="table"
					data-sort-class="table-active"
					data-sort-name="enabled"
					data-sort-order="desc"
					data-search="true"
					data-sortable="true"
				>
					<thead>
						<tr>
							<th data-sortable="true">Command</th>
							<th data-sortable="true" data-field="enabled">Enabled</th>
							<th data-sortable="true">Cron expression</th>
							<th data-sortable="true">Message diff</th>
						</tr>
					</thead>
					<tbody>
						for _, c := range scheduled {
							<tr>
								<td><code>{ channel.Prefix }{ c.R.CommandInfo.Name }</code></td>
								<td>
									@yesNo(c.Enabled)
								</td>
								<td><code>{ c.CronExpression }</code></td>
								<td>{ fmt.Sprint(c.MessageDiff) }</td>
							</tr>
						}
					</tbody>
				</table>
			}
		</div>
	</div>
}

templ ChannelScheduledPage(channel *models.Channel, repeated models.RepeatedCommandSlice, scheduled models.ScheduledCommandSlice) {
	@PageTemplate(getBrand(ctx)+" - "+displayNameFor(channel), channelMeta(), channelScripts(), channelScheduledBody(channel, repeated, scheduled))
}

// Variables page
templ channelVariablesBody(channel *models.Channel, variables models.VariableSlice) {
	@channelSidebarMobile(channel, "variables")
	<div class="columns is-fullheight is-clipped">
		@channelSidebar(channel, "variables")
		<div class="column is-main-content content">
			<span class="title is-1">{ displayNameFor(channel) }</span><span class="subtitle is-3">Variables</span>
			<hr/>
			if len(variables) == 0 {
				<p>No variables.</p>
			} else {
				<table
					class="table is-striped is-hoverable is-fullwidth"
					data-toggle="table"
					data-sort-class="table-active"
					data-sort-name="name"
					data-sort-order="asc"
					data-search="true"
					data-sortable="true"
				>
					<thead>
						<tr>
							<th data-sortable="true" data-field="name">Name</th>
							<th data-sortable="true">Value</th>
						</tr>
					</thead>
					<tbody>
						for _, v := range variables {
							<tr>
								<td>{ v.Name }</td>
								<td>{ v.Value }</td>
							</tr>
						}
					</tbody>
				</table>
			}
		</div>
	</div>
}

templ ChannelVariablesPage(channel *models.Channel, variables models.VariableSlice) {
	@PageTemplate(getBrand(ctx)+" - "+displayNameFor(channel), channelMeta(), channelScripts(), channelVariablesBody(channel, variables))
}

// Highlights page
func formatHighlightTimestamp(highlightedAt time.Time, startedAt time.Time, valid bool) string {
	if !valid {
		return ""
	}
	return durafmt.Parse(highlightedAt.Sub(startedAt).Truncate(time.Second)).String()
}

templ channelHighlightsBody(channel *models.Channel, highlights models.HighlightSlice) {
	@channelSidebarMobile(channel, "highlights")
	<div class="columns is-fullheight is-clipped">
		@channelSidebar(channel, "highlights")
		<div class="column is-main-content content">
			<span class="title is-1">{ displayNameFor(channel) }</span><span class="subtitle is-3">Highlights</span>
			<hr/>
			if len(highlights) == 0 {
				<p>No highlights.</p>
			} else {
				<table
					class="table is-striped is-hoverable is-fullwidth"
					data-toggle="table"
					data-sort-class="table-active"
					data-sort-name="created_at"
					data-sort-order="desc"
					data-search="true"
					data-sortable="true"
				>
					<thead>
						<tr>
							<th data-sortable="true" data-field="created_at" data-formatter="timeFormatter" data-sorter="timeSorter">Created at</th>
							<th data-sortable="true">Timestamp</th>
							<th data-sortable="true">Status</th>
							<th data-sortable="true">Game</th>
						</tr>
					</thead>
					<tbody>
						for _, h := range highlights {
							<tr>
								<td>{ h.HighlightedAt.Format(time.RFC3339) }</td>
								<td>{ formatHighlightTimestamp(h.HighlightedAt, h.StartedAt.Time, h.StartedAt.Valid) }</td>
								<td>{ h.Status }</td>
								<td>{ h.Game }</td>
							</tr>
						}
					</tbody>
				</table>
			}
		</div>
	</div>
}

templ ChannelHighlightsPage(channel *models.Channel, highlights models.HighlightSlice) {
	@PageTemplate(getBrand(ctx)+" - "+displayNameFor(channel), channelMeta(), channelScripts(), channelHighlightsBody(channel, highlights))
}
