templ channelAutorepliesBody(channel *models.Channel, autoreplies models.AutoreplySlice) {
	@channelSidebarMobile(channel, "autoreplies")
	<div class="columns is-fullheight is-clipped">
		@channelSidebar(channel, "autoreplies")
